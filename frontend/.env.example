# Default: deterministic mock analyzer.
MANYANG_ANALYSIS_MODE=mock

# Enable real LLM analysis on the server route.
# MANYANG_ANALYSIS_MODE=llm
# OPENAI_API_KEY=sk-...
# MANYANG_OPENAI_MODEL=gpt-5-mini
# MANYANG_LLM_TIMEOUT_MS=45000

# Supabase project connection.
# Copy these into frontend/.env with real values from the Supabase dashboard.
# Project URL for project fgetveyfzejrokjxrjkz:
# NEXT_PUBLIC_SUPABASE_URL=https://fgetveyfzejrokjxrjkz.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
#
# Server-only key. Never prefix this with NEXT_PUBLIC and never expose it in client code.
# SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Optional: local database admin/migration connection.
# Use this only from local scripts or Supabase CLI. Never expose it to browser code.
# Recommended for local schema work when direct IPv6 is not available: Session pooler.
# Copy the Session pooler connection string from Supabase Dashboard > Connect.
# SUPABASE_DB_URL=postgresql://postgres.fgetveyfzejrokjxrjkz:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
#
# Supabase CLI can also use the DB password separately after `supabase link`.
# SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
#
# Direct connection is fine for migrations/admin if your network supports IPv6.
# SUPABASE_DB_DIRECT_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.fgetveyfzejrokjxrjkz.supabase.co:5432/postgres

# Enable real embedding ingestion for the local RAG vector index.
# MANYANG_RAG_EMBEDDINGS_MODE=openai
# MANYANG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# MANYANG_RAG_VECTOR_INDEX_PATH=../output/rag/dream-rag-ko.json
# MANYANG_RAG_VECTOR_INDEX_PATH_KO=../output/rag/dream-rag-ko.json
# MANYANG_RAG_VECTOR_INDEX_PATH_EN=../output/rag/dream-rag-en.json

# Korean morphological analyzer service (optional). When set, the matcher uses its
# lemmas for better inflected-form matching; when unset it falls back to lexical matching.
# MANYANG_LEMMATIZER_URL=http://localhost:8080
# MANYANG_LEMMATIZER_TIMEOUT_MS=2000

# Tarot event access. Default is open; set to 0 after the event to lock
# three-card readings back to Moon Pass/admin access.
# NEXT_PUBLIC_TAROT_THREE_CARD_FREE_EVENT=1
